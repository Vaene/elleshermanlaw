/**
 * Implements hook_preprocess_page() for block templates.
 */

function classic_parallax_theme_preprocess_page(&$variables) {

  // Add responsive class for footer.
  if (!empty($variables['page']['footer_first']) && !empty($variables['page']['footer_second']) && !empty($variables['page']['footer_third'])) {
    $variables['footer_class'] = 'col-md-4';
  }
  elseif((!empty($variables['page']['footer_first']) && !empty($variables['page']['footer_second'])) or (!empty($variables['page']['footer_first']) && !empty($variables['page']['footer_third'])) or (!empty($variables['page']['footer_third']) && !empty($variables['page']['footer_second']))) {
    $variables['footer_class'] = 'col-md-6';
  }
  else {
    $variables['footer_class'] = 'col-md-12';
  }

  // Add information about the number of sidebars.
  if (!empty($variables['page']['sidebar_first']) && !empty($variables['page']['sidebar_second'])) {
    $variables['contentlayout'] = 'col-md-6';
    $variables['sidebarfirst'] = 'col-md-3';
    $variables['sidebarsecond'] = 'col-md-3';
  }
  elseif (!empty($variables['page']['sidebar_first'])) {
    $variables['contentlayout'] = 'col-md-9 ';
    $variables['sidebarfirst'] = 'col-md-3';
  }
  elseif (!empty($variables['page']['sidebar_second'])) {
    $variables['contentlayout'] = 'col-md-9';
    $variables['sidebarsecond'] = 'col-md-3';
  }
  else {
    $variables['contentlayout'] = 'col-md-12';
  }

  // Social media global variable.
  $variables['show_social_icon'] = theme_get_setting('show_social_icon');
  $variables['facebook_url'] = theme_get_setting('facebook_url');
  $variables['twitter_url'] = theme_get_setting('twitter_url');
  $variables['linkedin_url'] = theme_get_setting('linkedin_url');
  $variables['pinterest_url'] = theme_get_setting('pinterest_url');
  $variables['rss_url'] = theme_get_setting('rss_url');
  $variables['show_credit_link'] = theme_get_setting('show_credit_link');
  
  // Parallax menuid
  $variables['parallax_teams_menuid'] = theme_get_setting('parallax_teams_menuid');
  $variables['parallax_pricetable_menuid'] = theme_get_setting('parallax_pricetable_menuid');
  // $variables['parallax_services_menuid'] = theme_get_setting('parallax_services_menuid');
  // $variables['parallax_blocks_menuid'] = theme_get_setting('parallax_blocks_menuid');
  // $variables['parallax_footer_menuid'] = theme_get_setting('parallax_footer_menuid');
  
  // To get the current URL
  $current_url  = \Drupal::request()->getRequestUri();
  $current_path = explode("/", $current_url);
  $variables['current_path'] = $current_path[2];

  // Assign variable for slider
  if ($variables['is_front']) {
    if (theme_get_setting('show_slideshow','classic_parallax_theme') == 1) {
      $variables['show_slideshow'] = 1;
      $variables['slider_content'] = classic_parallax_theme_get_slider_content();
    }
    if (theme_get_setting('show_parallax','classic_parallax_theme') == 1) {
      $variables['show_parallax'] = 1;
      $variables['parallax_content'] = classic_parallax_theme_get_parallax_content();
    }
    if (theme_get_setting('show_parallax_teams','classic_parallax_theme') == 1) {
      $variables['show_parallax_teams'] = 1;
      $variables['parallax_teams_content'] = classic_parallax_theme_get_parallax_teams_content();
    }
    if (theme_get_setting('show_parallax_services','classic_parallax_theme') == 1) {
      $variables['show_parallax_services'] = 1;
      $variables['parallax_services_content'] = classic_parallax_theme_get_parallax_services_content();
    }
    if (theme_get_setting('show_parallax_pricetable','classic_parallax_theme') == 1) {
      $variables['show_parallax_pricetable'] = 1;
      $variables['parallax_pricetable_content'] = classic_parallax_theme_get_parallax_pricetable_content();
    }
    if (theme_get_setting('show_parallax_blocks','classic_parallax_theme') == 1) {
      $variables['show_parallax_blocks'] = 1;
      $variables['parallax_blocks_content'] = classic_parallax_theme_get_parallax_blocks_content();
    }
    if (theme_get_setting('show_parallax_footer','classic_parallax_theme') == 1) {
      $variables['show_parallax_footer'] = 1;
      $variables['parallax_footer_content'] = classic_parallax_theme_get_parallax_footer_content();
    }
  }
}

/**
 * Implements hook_preprocess_menu().
 */
function classic_parallax_theme_preprocess_menu(&$variables, $hook) {
  if ($hook == 'menu__main') { // We're doing that for main menu.
    // Get the current path.
    $current_path = \Drupal::request()->getRequestUri();
    $items = $variables['items'];
    foreach ($items as $key => $item) {
      // If path is current_path, set active to li.
      if ($item['url']->toString() == $current_path) {
      // Add active link.
      $variables['items'][$key]['attributes']['class'] = 'active';
      }
    }
  }
}

/**
 * Slider
 * Implements custom function for get slider content.
 */
function classic_parallax_theme_get_slider_content() {
  $slider_content = array();
  for ($i = 1; $i <= theme_get_setting('no_of_slides'); $i++) {
    $fid = theme_get_setting('slide_image_path'.$i,'classic_parallax_theme');
    $description = theme_get_setting('slide_description_'.$i,'classic_parallax_theme');
    if (!empty($fid)) {
      $file = file_load($fid[0]);
      $uri = $file->getFileUri();
      $path = file_create_url($uri);
    }
    else {
      $path = base_path() . drupal_get_path('theme', 'classic_parallax_theme') . theme_get_setting('slide_image_path_' . $i, 'classic_parallax_theme');
    }
    $slider_content[$i] = '<li>
      <img src="' . $path . '" alt="Slider Banner" />
      <div class="slider-caption">
        <h2 class="slider-title">' . theme_get_setting('slide_title_' . $i, 'classic_parallax_theme').'</h2>
        <p class="slider-description">' . $description .'</p>
        <a href=' . theme_get_setting('slide_url_' . $i, 'classic_parallax_theme') . ' class="more-link">Read more</a>
      </div>
    </li>';
  }
  return $slider_content;
}

/**
 * Parallax
 * Implements custom function for get parallax content.
 */
function classic_parallax_theme_get_parallax_content() {
  $parallax_content = array();
  for ($i = 1; $i <= theme_get_setting('no_of_parallax'); $i++) {
    $fid = theme_get_setting('parallax_image_path'.$i,'classic_parallax_theme');
    if (!empty($fid)) {
      $file = file_load($fid[0]);
      $uri = $file->getFileUri();
      $path = file_create_url($uri);
    }
    else {
      $path = base_path() . drupal_get_path('theme', 'classic_parallax_theme') . theme_get_setting('parallax_image_path_' . $i, 'classic_parallax_theme');
    }
    $parallax_content[$i] = '<li class="parallax-window parallax-slide parallax-fullwidth parallax-slide'. $i .'" id="'. theme_get_setting('parallax_menuid_' . $i, 'classic_parallax_theme') .'"data-image-src="' . $path . '">
      <div class="parallax-details wow slideInLeft">
        <p class="parallax-title">' . theme_get_setting('parallax_title_' . $i, 'classic_parallax_theme').'</p>
        <p class="parallax-description">' . theme_get_setting('parallax_description_' . $i, 'classic_parallax_theme').'</p>
        <a href=' . theme_get_setting('parallax_url_' . $i, 'classic_parallax_theme') . ' class="more-hyperlink"><i class="fas fa-chevron-right"></i></a>
      </div>
    </li>';
  }
  return $parallax_content;
}

/**
 * Parallax
 * Implements custom function for get team content.
 */
function classic_parallax_theme_get_parallax_teams_content() {
  $parallax_teams_content = array();
  for ($i = 1; $i <= theme_get_setting('no_of_parallax_teams'); $i++) {
    $fid = theme_get_setting('parallax_teams_image_path'.$i,'classic_parallax_theme');
    if (!empty($fid)) {
      $file = file_load($fid[0]);
      $uri = $file->getFileUri();
      $path = file_create_url($uri);
    }
    else {
      $path = base_path() . drupal_get_path('theme', 'classic_parallax_theme') . theme_get_setting('parallax_teams_image_path_' . $i, 'classic_parallax_theme');
    }
    $parallax_teams_content[$i] = '<div class="col-sm parallax-team parallax-team wow slideInLeft'. $i .'"data-image-src="' . $path . '">
      <div class="team-image"><img src="' . $path . '" alt="Parallax Team" /></div>
        <div class="team-details">
          <h3>'. theme_get_setting('parallax_teams_title_' . $i, 'classic_parallax_theme').'</h3>
          <p class="team-designation">'. theme_get_setting('parallax_teams_designation_' . $i, 'classic_parallax_theme').'</p>
          <div class="team-description">' . theme_get_setting('parallax_teams_description_' . $i, 'classic_parallax_theme').'</div>
          <ul class="social-media-link">
            <li><a href="'. theme_get_setting('parallax_teams_facebook_' . $i, 'classic_parallax_theme').'"><i class="fab fa-facebook-f"></i></a></li>
            <li><a href="'. theme_get_setting('parallax_teams_twitter_' . $i, 'classic_parallax_theme').'"><i class="fab fa-twitter"></i></a></li>
            <li><a href="'. theme_get_setting('parallax_teams_linkedin_' . $i, 'classic_parallax_theme').'"><i class="fab fa-linkedin-in"></i></a></li>
          </ul>
        </div>
      </div>';
  }
  return $parallax_teams_content;
}

