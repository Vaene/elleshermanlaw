/**
 * Implements hook_form_system_theme_settings_alter().
 */

function classic_parallax_theme_form_system_theme_settings_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state) {

  $form['classic_parallax_theme_info'] = array(
    '#markup' => '<h2><br/>Advanced theme settings</h2><div class="messages messages--warning">Clear cache after making any changes in theme settings. <a href="../../config/development/performance">Click here to clear cache</a></div>'
  );

  /*-------------------------------------------- 
    Slider Configuration
  --------------------------------------------*/

  $form['classic_parallax_theme_settings']['slideshow'] = array(
    '#type' => 'details',
    '#title' => t('Slideshow'),
    '#collapsible' => TRUE,
    '#collapsed' => FALSE,
  );
  $form['classic_parallax_theme_settings']['slideshow']['no_of_slides'] = array(
    '#type' => 'textfield',
    '#title' => t('Number of slides'),
    '#default_value' => theme_get_setting('no_of_slides'),
    '#description'  => t("Enter the number of slides required & Save configuration"),
    '#markup' => '<div class="messages messages--warning">Clear caches after making any changes in theme settings. <a href="../../config/development/performance">Click here to clear cache</a></div>',
  );
  $form['classic_parallax_theme_settings']['slideshow']['show_slideshow'] = array(
    '#type' => 'checkbox',
    '#title' => t('Show slideshow'),
    '#default_value' => theme_get_setting('show_slideshow'),
  );
  $form['classic_parallax_theme_settings']['slideshow']['slide'] = array(
    '#markup' => t('Change the banner image, title, description and link using below fieldset'),
  );
  for ($i = 1; $i <= theme_get_setting('no_of_slides'); $i++) {
    $form['classic_parallax_theme_settings']['slideshow']['slide' . $i] = array(
      '#type' => 'details',
      '#title' => t('Slide '.$i),
      '#collapsible' => TRUE,
      '#collapsed' => TRUE,
    );
    $form['classic_parallax_theme_settings']['slideshow']['slide' . $i]['slide_image_path' . $i] = array(
      '#type' => 'managed_file',
      '#title' => t('Slide '.$i.' image'),
      '#default_value' => theme_get_setting('slide_image_path'.$i,'classic_parallax_theme'),
      '#upload_location' => 'public://',
    );
    $form['classic_parallax_theme_settings']['slideshow']['slide' . $i]['slide_title_' . $i] = array(
      '#type' => 'textfield',
      '#title' => t('Slide '.$i.' title'),
      '#default_value' => theme_get_setting('slide_title_' . $i,'classic_parallax_theme'),
    );
    $form['classic_parallax_theme_settings']['slideshow']['slide' . $i]['slide_description_' . $i] = array(
      '#type' => 'textarea',
      '#title' => t('Slide '.$i.' description'),
      '#default_value' => theme_get_setting('slide_description_' . $i,'classic_parallax_theme'),
    );    
    $form['classic_parallax_theme_settings']['slideshow']['slide' . $i]['slide_url_' . $i] = array(
      '#type' => 'textfield',
      '#title' => t('Slide '.$i.' URL'),
      '#default_value' => theme_get_setting('slide_url_' . $i,'classic_parallax_theme'),
    );
    // Make the uploaded images permanent.
    $image = theme_get_setting('slide_image_path'.$i,'classic_parallax_theme');
    if(!empty($image)){
      $file = File::load($image[0]);
      $file->status = FILE_STATUS_PERMANENT;
      $file->save();
      $file_usage = \Drupal::service('file.usage');
      $file_usage_check = $file_usage->listUsage($file);
      if (empty($file_usage_check)) {
        $file_usage->add($file, 'classic_parallax_theme', 'theme', $image[0]);
      }
    }
  }

  /*-------------------------------------------- 
      Parallax Configuration
  --------------------------------------------*/

  $form['classic_parallax_theme_settings']['parallax'] = array(
    '#type' => 'details',
    '#title' => t('Parallax slides'),
    '#collapsible' => TRUE,
    '#collapsed' => FALSE,
  );
  $form['classic_parallax_theme_settings']['parallax']['no_of_parallax'] = array(
    '#type' => 'number',
    '#title' => t('Number of Parallax slides required'),
    '#default_value' => theme_get_setting('no_of_parallax'),
    '#max' => 8,
    '#description'  => t("Enter the number of parallax slide required & Save configuration"),
    '#markup' => '<div class="messages messages--warning">Clear caches after making any changes in theme settings. <a href="../../config/development/performance">Click here to clear cache</a></div>',
  );
  $form['classic_parallax_theme_settings']['parallax']['show_parallax'] = array(
    '#type' => 'checkbox',
    '#title' => t('Show Parallax'),
    '#default_value' => theme_get_setting('show_parallax'),
  );
  $form['classic_parallax_theme_settings']['parallax']['parallaxslide'] = array(
    '#markup' => t('Change the Parallax background image, title, description and link using below fieldset.'),
  );
  for ($i = 1; $i <= theme_get_setting('no_of_parallax'); $i++) {
    $form['classic_parallax_theme_settings']['parallax']['parallaxslide' . $i] = array(
      '#type' => 'details',
      '#title' => t('Parallax '.$i),
      '#collapsible' => TRUE,
      '#collapsed' => TRUE,
    );
    $form['classic_parallax_theme_settings']['parallax']['parallaxslide' . $i]['parallax_menuid_' . $i] = array(
      '#type' => 'textfield',
      '#title' => t('Parallax '.$i.' block Id(for menu)'),
      '#default_value' => theme_get_setting('parallax_menuid_' . $i,'classic_parallax_theme'),
    );
    $form['classic_parallax_theme_settings']['parallax']['parallaxslide' . $i]['parallax_image_path' . $i] = array(
      '#type' => 'managed_file',
      '#title' => t('Parallax '.$i.' background image'),
      '#default_value' => theme_get_setting('parallax_image_path'.$i,'classic_parallax_theme'),
      '#upload_location' => 'public://',
    );
    $form['classic_parallax_theme_settings']['parallax']['parallaxslide' . $i]['parallax_title_' . $i] = array(
      '#type' => 'textfield',
      '#title' => t('Parallax '.$i.' title'),
      '#default_value' => theme_get_setting('parallax_title_' . $i,'classic_parallax_theme'),
    );
    $form['classic_parallax_theme_settings']['parallax']['parallaxslide' . $i]['parallax_description_' . $i] = array(
      '#type' => 'textarea',
      '#title' => t('Parallax '.$i.' description'),
      // '#format' => 'full_html',
      '#default_value' => theme_get_setting('parallax_description_' . $i,'classic_parallax_theme'),
    );
    $form['classic_parallax_theme_settings']['parallax']['parallaxslide' . $i]['parallax_url_' . $i] = array(
      '#type' => 'textfield',
      '#title' => t('Parallax '.$i.' URL'),
      '#default_value' => theme_get_setting('parallax_url_' . $i,'classic_parallax_theme'),
    );
    // Make the uploaded images permanent.
    $image = theme_get_setting('parallax_image_path'.$i,'classic_parallax_theme');
    if(!empty($image)){
      $file = File::load($image[0]);
      $file->status = FILE_STATUS_PERMANENT;
      $file->save();
      $file_usage = \Drupal::service('file.usage');
      $file_usage_check = $file_usage->listUsage($file);
      if (empty($file_usage_check)) {
        $file_usage->add($file, 'classic_parallax_theme', 'theme', $image[0]);
      }
    }
  }

  /*-------------------------------------------- 
      Parallax Teams Configuration
  --------------------------------------------*/

  $form['classic_parallax_theme_settings']['parallax_teams'] = array(
    '#type' => 'details',
    '#title' => t('Teams'),
    '#collapsible' => TRUE,
